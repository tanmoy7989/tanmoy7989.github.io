---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { settings } from '../settings';

const placeholder = '/images/research/placeholder.svg';

const items = (await getCollection('Research'))
  .map((item) => ({
    ...item,
    img: item.data.img ?? placeholder,
    slug: `/research/${item.id}`,
  }))
  .sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));
---

<Layout title={`Research — ${settings.siteTitle}`}>
  <section class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold mb-8">Research Projects</h1>
    <div class="grid gap-8">
      {items.map((item) => (
        <article class="card bg-base-200 border border-base-300 transition-all hover:shadow-lg hover:border-accent/40">
          <div class="card-body">
            <div class="flex flex-col md:flex-row gap-6">
              <div class="md:w-1/3">
                <img
                  src={item.img}
                  alt={item.data.title}
                  class="w-full h-48 object-cover rounded-lg"
                />
              </div>
              <div class="md:w-2/3 flex flex-col">
                <h2 class="card-title text-xl mb-1">
                  <a href={item.slug} class="hover:text-accent transition-colors">
                    {item.data.title}
                  </a>
                </h2>
                {item.data.venue && (
                  <p class="text-sm text-base-content/60 italic mb-2">{item.data.venue}</p>
                )}
                <p class="text-base text-base-content/80 flex-grow">{item.data.description}</p>
                <div class="flex gap-2 flex-wrap mt-3">
                  {item.data.tags?.map((tag) => (
                    <span class="badge badge-outline badge-accent badge-sm">{tag}</span>
                  ))}
                </div>
                <div class="card-actions justify-end mt-4">
                  <a href={item.slug} class="btn btn-sm btn-accent text-accent-content">
                    Learn More
                  </a>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
