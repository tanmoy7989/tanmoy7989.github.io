---
import Layout from '../layouts/Layout.astro';
import { settings } from '../settings';
import SocialIcons from '../components/ui/SocialIcons.astro';
---

<Layout title={settings.siteTitle} description={settings.siteDescription}>
  <div class="flex flex-col md:flex-row md:items-start gap-10 md:gap-14 max-w-5xl mx-auto py-16 px-6">
    <div class="flex flex-col gap-4 flex-1 min-w-0 order-2 md:order-1">
      <h1 class="text-4xl font-bold">
        <span class="text-accent">{settings.authorName}</span>
      </h1>
      <p class="text-lg text-base-content/60">{settings.authorLabel}</p>
      <p class="text-base leading-relaxed whitespace-pre-line" set:html={settings.bio} />
      <div class="flex flex-wrap items-center gap-4 mt-2">
        <SocialIcons />
        <a
          href={settings.resumePdf}
          download
          class="btn btn-sm btn-accent text-accent-content"
        >
          Download CV (PDF)
        </a>
      </div>
    </div>
    <div class="flex-shrink-0 mx-auto md:mx-0 order-1 md:order-2">
      <img
        src={settings.profileImage}
        alt={settings.authorName}
        class="rounded-full w-56 h-56 sm:w-64 sm:h-64 lg:w-72 lg:h-72 object-cover shadow-lg"
      />
    </div>
  </div>
</Layout>
