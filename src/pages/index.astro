---
import Layout from '../layouts/Layout.astro';
import { settings } from '../settings';
import SocialIcons from '../components/ui/SocialIcons.astro';
---

<Layout title={settings.siteTitle} description={settings.siteDescription}>
  <div class="flex flex-col md:flex-row gap-10 items-center max-w-4xl mx-auto py-16 px-6">
    <div class="flex-shrink-0">
      <img
        src={settings.profileImage}
        alt={settings.authorName}
        class="rounded-full w-48 h-48 object-cover shadow-lg"
      />
    </div>
    <div class="flex flex-col gap-4">
      <h1 class="text-4xl font-bold">
        <span class="text-accent">{settings.authorName}</span>
      </h1>
      <p class="text-lg text-base-content/60">{settings.authorLabel}</p>
      <p class="text-base leading-relaxed whitespace-pre-line">{settings.bio}</p>
      <div class="flex flex-wrap items-center gap-4 mt-2">
        <SocialIcons />
        <a
          href={settings.resumePdf}
          download
          class="btn btn-sm btn-accent text-accent-content"
        >
          Download CV (PDF)
        </a>
      </div>
    </div>
  </div>
</Layout>
